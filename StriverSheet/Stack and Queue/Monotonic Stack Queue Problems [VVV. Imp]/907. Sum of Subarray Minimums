//intution :- For each element → in how many subarrays is it the minimum?

//optimal approch tc = O(5n) sc = O(2N)
class Solution {
public:
    vector<int> findnse(vector<int> arr){
        vector<int> nse(arr.size());
        stack<int> st;
        for(int i = arr.size()-1 ; i >= 0 ; i--){
            while(!st.empty() && arr[st.top()] >= arr[i]){
                st.pop();
            }
            if(st.empty()) nse[i] = arr.size();
            else nse[i] = st.top();
            st.push(i);
        }
        return nse;
    }
    vector<int> findpse(vector<int> arr){
        vector<int> pse(arr.size());
        stack<int> st;
        for(int i = 0 ; i < arr.size() ; i++){
            while(!st.empty() && arr[st.top()] > arr[i]){
                st.pop();
            }
            if(st.empty()) pse[i] = -1;
            else pse[i] = st.top();
            st.push(i);
        }
        return pse;
    }
    int sumSubarrayMins(vector<int>& arr) {
        vector<int> nse = findnse(arr);
        vector<int> pse = findpse(arr);
        long long total = 0,mod = 1e9 + 7;
        for(int i = 0 ; i < arr.size() ; i++){
            int left = i-pse[i];
            int right = nse[i]-i;
            total += (right * left * (long long)arr[i])%mod;
            total %= mod;
        }
        return total;
    }
};

// brute force tc = O(n^2) sc = O(1)
class Solution {
public:
    int sumSubarrayMins(vector<int>& arr) {
        int mod = (int)1e9+7;
        long sum = 0;
        for(int i = 0 ; i < arr.size() ; i++){
            int mini = INT_MAX;
            for(int j = i ; j < arr.size() ; j++){
                mini = min(mini,arr[j]);
                sum += mini;
            }
        }
        return sum%mod;
    }
};

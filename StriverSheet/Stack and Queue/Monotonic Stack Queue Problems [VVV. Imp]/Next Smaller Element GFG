// optimal approch tc = O(2N) sc = O(2N)
class Solution {
  public:
    vector<int> nextSmallerEle(vector<int>& arr) {
        stack<int> st;
        vector<int> nge(arr.size());
        for(int i = arr.size()-1; i >= 0 ; i--){
            while(!st.empty() && st.top() >= arr[i]){
                st.pop();
            }
            if(st.empty()) nge[i] = -1;
            else nge[i] = st.top();
            st.push(arr[i]);
        }
        return nge;
    }
};

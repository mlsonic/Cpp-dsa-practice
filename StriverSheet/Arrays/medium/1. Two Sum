//brute force tc = O(n^2) sc = O(1)
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int n = nums.size();
        for(int i = 0; i < n; i++){
            for(int j = 0; j < n; j++){
                if(i == j) continue;
                if(nums[i] + nums[j] == target) return {i,j};
            }
        }    
        return {};   
    }
};

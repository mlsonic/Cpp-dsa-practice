// optimal approch tc = O(n) sc = O(n)
class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        unordered_map<int,int> mpp;
        mpp[0] = 1;
        int presum = 0; int cnt = 0;
        for(int i = 0; i < nums.size(); i++){
            presum += nums[i];
            int remove = presum - k;
            cnt += mpp[remove];
            mpp[presum]++;
        }
        return cnt;
    }
};

//Brute froce tc = O(n^2) sc = O(1)
class Solution {
public:
    int subarraySum(vector<int>& nums, int k) {
        int n=nums.size();
        int cnt=0;
        for(int i=0;i<n;i++){
            int sum=0;
            for(int j=i;j<n;j++){
                 sum+=nums[j];
                 if(sum==k){
                    cnt++;
                 }
            }
        } 
        return cnt;               
    }
};

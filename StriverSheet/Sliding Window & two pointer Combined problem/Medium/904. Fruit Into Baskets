// Brute force tc = O(n^2) sc = O(2)
class Solution {
public:
    int totalFruit(vector<int>& fruits) {
        int n = fruits.size();
        int total = 0;
        for(int i = 0 ; i < n ; i++){
            vector<int> arr(2,-1);
            arr[0] = fruits[i];
            int cnt = 0;
            for(int j = i ; j < n ; j++){
                if(fruits[j] == arr[0] || fruits[j] == arr[1]){
                    cnt++;
                }
                else if(arr[1] == -1){
                    arr[1] = fruits[j];
                    cnt++;
                }
                else break;
            }
            cout << cnt;
            total = max(total,cnt);
        }  
        return total;
    }
};

//striver brute force tc = O(n^2) sc = O(1)
class Solution {
public:
    int longestOnes(vector<int>& nums, int k) {
        int n = nums.size();
        int maxi = 0;
        for(int i = 0; i < n ; i++){
            int zeros = 0;
            for(int j = i ; j < n ; j++){
                if(nums[j] == 0) zeros++;;
                if(zeros <= k){
                  maxi = max(maxi,j-i+1); 
                }
                else break;
            }
        }
        return maxi;
    }
};

// My brute force tc = O(n^2) sc = O(1)
class Solution {
public:
    int longestOnes(vector<int>& nums, int k) {
        int n = nums.size();
        int maxi = 0;
        for(int i = 0; i < n ; i++){
            int len = 0,k1 = k;
            for(int j = i ; j < n ; j++){
                if(nums[j] == 1) len += 1;
                else{
                    if(k1 > 0){
                        len += 1;
                        k1--;
                    }
                    else break;
                }
                maxi = max(maxi,len);
            }
        }
        return maxi;
    }
};
